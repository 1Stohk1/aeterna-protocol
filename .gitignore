# --- Julia ---
# By default we ignore Manifest.toml (Julia convention for libraries: only
# the Project.toml is sources of truth, the lockfile is environment-local).
# BUT scientific/ is an APPLICATION, not a library: aeterna.toml pins the
# Julia version (freeze_julia_version) and demands a hash of the manifest
# (require_manifest_hash). For reproducibility the lockfile is part of the
# release artifact, so we explicitly un-ignore it.
Manifest.toml
!scientific/Manifest.toml
/scientific/.CondaPkg/
deps/usr/
deps/deps.jl
deps/build.log

# --- Rust / Cargo (future santuario, chain) ---
target/
target-codex/
**/*.rs.bk
Cargo.lock

# --- Go (future chain via Cosmos SDK) ---
/chain/bin/
/chain/build/
vendor/

# --- Santuario: sensitive runtime artifacts ---
# NEVER commit these. They are derived from the TPM and contain sovereignty.
santuario/vault/
santuario/keys/
santuario/checkpoints/
*.pem
*.key
*.kyber
*.dilithium
wallet.*

# --- Models (LLM weights pulled at runtime) ---
santuario-runtime/models/
*.gguf
*.safetensors

# --- IDE / editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs and local config overrides ---
*.log
logs/
aeterna.local.toml
.env
.env.local
.uv-cache/

# --- IPFS / storage caches ---
.ipfs/
pin_cache/
